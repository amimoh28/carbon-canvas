{
  "name": "carbon-canvas",
  "private": true,
  "version": "0.1.0",
  "description": "Carbon Canvas — privacy-first AI usage intelligence (MVP prototype)",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:calculator": "node --test apps/site/calculator-engine.test.mjs",
    "dev:web": "pnpm --filter @carbon-canvas/web dev",
    "build:extension": "pnpm --filter @carbon-canvas/extension build"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
