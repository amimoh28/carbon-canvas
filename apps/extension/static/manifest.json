{
  "manifest_version": 3,
  "name": "Carbon Canvas",
  "version": "0.1.0",
  "description": "See how you use AI — privately. Tracks usage metadata only; never reads or stores your conversations.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*"
  ],
  "background": { "service_worker": "worker.js" },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Carbon Canvas — your AI today"
  }
}
